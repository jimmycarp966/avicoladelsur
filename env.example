# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Botpress Configuration
BOTPRESS_WEBHOOK_URL=your_botpress_webhook_url
BOTPRESS_API_KEY=your_botpress_api_key

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=your_twilio_whatsapp_number

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Maps API (Opcional - para optimización de rutas)
# Si no está configurada, el sistema usa algoritmo local (Nearest Neighbor + 2-opt)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Cloud Configuration
# Service Account JSON (base64 encoded o ruta al archivo)
# Opción 1: Base64 encoded JSON (recomendado para producción)
GOOGLE_CLOUD_SERVICE_ACCOUNT_BASE64=your-base64-encoded-service-account-json

# Opción 2: Ruta al archivo JSON (solo para desarrollo local)
# GOOGLE_CLOUD_SERVICE_ACCOUNT_PATH=./google-cloud-service-account.json

# Google Cloud Project ID
GOOGLE_CLOUD_PROJECT_ID=your-google-cloud-project-id

# Google Cloud Region (ej: us-central1, southamerica-east1)
GOOGLE_CLOUD_REGION=southamerica-east1

# Google Maps Fleet Routing API
GOOGLE_MAPS_FLEET_ROUTING_API_KEY=your-fleet-routing-api-key

# Cloud Optimization API
GOOGLE_OPTIMIZATION_API_ENABLED=true

# Dialogflow Configuration
GOOGLE_DIALOGFLOW_PROJECT_ID=your-dialogflow-project-id
GOOGLE_DIALOGFLOW_AGENT_ID=your-dialogflow-agent-id
GOOGLE_DIALOGFLOW_LANGUAGE_CODE=es-AR

# Speech-to-Text API
GOOGLE_SPEECH_TO_TEXT_ENABLED=true
GOOGLE_SPEECH_TO_TEXT_LANGUAGE_CODE=es-AR

# Document AI Configuration
GOOGLE_DOCUMENT_AI_PROJECT_ID=your-document-ai-project-id
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID_FACTURAS=your-facturas-processor-id
GOOGLE_DOCUMENT_AI_PROCESSOR_ID_REMITOS=your-remitos-processor-id

# Vertex AI Configuration
GOOGLE_VERTEX_AI_ENABLED=true
GOOGLE_VERTEX_AI_LOCATION=us-central1

# Cloud AutoML Configuration
GOOGLE_AUTOML_ENABLED=true
GOOGLE_AUTOML_LOCATION=us-central1

# Gemini API Configuration
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
GOOGLE_GEMINI_MODEL=gemini-3-pro-preview
GOOGLE_GEMINI_LOCATION=us-central1