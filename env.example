# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Botpress Configuration
BOTPRESS_WEBHOOK_URL=your_botpress_webhook_url
BOTPRESS_API_KEY=your_botpress_api_key

# Twilio Configuration (Mantenido como respaldo durante migración)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=your_twilio_whatsapp_number

# WhatsApp Business API (Meta) Configuration
# Token de acceso permanente de WhatsApp Business API
WHATSAPP_META_ACCESS_TOKEN=your_whatsapp_meta_access_token
# ID del número de teléfono de WhatsApp Business (se encuentra en Meta Business)
WHATSAPP_META_PHONE_NUMBER_ID=your_whatsapp_meta_phone_number_id
# App ID de Meta (opcional, para funcionalidades avanzadas)
WHATSAPP_META_APP_ID=your_whatsapp_meta_app_id
# App Secret de Meta (opcional, para funcionalidades avanzadas)
WHATSAPP_META_APP_SECRET=your_whatsapp_meta_app_secret
# Token para verificar el webhook (debe coincidir con el configurado en Meta)
WHATSAPP_META_VERIFY_TOKEN=change-this-to-a-long-random-verify-token
# URL del webhook (opcional, se usa para notificaciones)
WHATSAPP_META_WEBHOOK_URL=https://your-domain.com/api/webhooks/whatsapp-meta
# Proveedor de WhatsApp a usar: 'meta' o 'twilio' (auto-detecta si no se especifica)
WHATSAPP_PROVIDER=meta
# Habilitar botones interactivos (true/false, default: true si Meta está configurado)
WHATSAPP_ENABLE_BUTTONS=true

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WEBMCP_ENABLED=false

# Google Maps API (Opcional - para optimización de rutas)
# Si no está configurada, el sistema usa algoritmo local (Nearest Neighbor + 2-opt)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Cloud Configuration
# Service Account JSON (base64 encoded o ruta al archivo)
# Opción 1: Base64 encoded JSON (recomendado para producción)
GOOGLE_CLOUD_SERVICE_ACCOUNT_BASE64=your-base64-encoded-service-account-json

# Opción 2: Ruta al archivo JSON (solo para desarrollo local)
# GOOGLE_CLOUD_SERVICE_ACCOUNT_PATH=./google-cloud-service-account.json

# Google Cloud Project ID
GOOGLE_CLOUD_PROJECT_ID=your-google-cloud-project-id

# Google Cloud Region (ej: us-central1, southamerica-east1)
GOOGLE_CLOUD_REGION=southamerica-east1

# Google Maps Fleet Routing API
GOOGLE_MAPS_FLEET_ROUTING_API_KEY=your-fleet-routing-api-key

# Cloud Optimization API
GOOGLE_OPTIMIZATION_API_ENABLED=true

# Dialogflow Configuration
GOOGLE_DIALOGFLOW_PROJECT_ID=your-dialogflow-project-id
GOOGLE_DIALOGFLOW_AGENT_ID=your-dialogflow-agent-id
GOOGLE_DIALOGFLOW_LANGUAGE_CODE=es-AR

# Speech-to-Text API
GOOGLE_SPEECH_TO_TEXT_ENABLED=true
GOOGLE_SPEECH_TO_TEXT_LANGUAGE_CODE=es-AR

# Document AI Configuration
GOOGLE_DOCUMENT_AI_PROJECT_ID=your-document-ai-project-id
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID_FACTURAS=your-facturas-processor-id
GOOGLE_DOCUMENT_AI_PROCESSOR_ID_REMITOS=your-remitos-processor-id

# Vertex AI Configuration
GOOGLE_VERTEX_AI_ENABLED=true
GOOGLE_VERTEX_AI_LOCATION=us-central1

# Cloud AutoML Configuration
GOOGLE_AUTOML_ENABLED=true
GOOGLE_AUTOML_LOCATION=us-central1

# Gemini API Configuration
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
GOOGLE_GEMINI_MODEL=gemini-3-pro-preview
GOOGLE_GEMINI_LOCATION=us-central1
# Legacy fallback (deprecado): GOOGLE_AI_API_KEY

# Hik-Connect OpenAPI (RRHH Horarios PoC)
HIK_CONNECT_BASE_URL=https://your-hik-connect-openapi-base-url
HIK_CONNECT_API_KEY=your-hik-connect-api-key
HIK_CONNECT_API_SECRET=your-hik-connect-api-secret
HIK_CONNECT_TOKEN_PATH=/api/hccgw/platform/v1/token/get
HIK_CONNECT_EVENTS_PATH=/api/hccgw/acs/v1/event/certificaterecords/search
HIK_CONNECT_EVENTS_METHOD=POST
HIK_CONNECT_AUTH_MODE=hcc_token
# Opcional: mapeo manual de personCode Hik -> empleado (UUID, legajo, dni o cuil)
# Formato: personCode=EMP001,otroCodigo=20424112594
HIK_CONNECT_PERSON_MAP=
