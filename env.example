# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_PROJECT_REF=your_supabase_project_ref
SUPABASE_ACCESS_TOKEN=your_supabase_access_token

# Public / client-side feature flags
NEXT_PUBLIC_WEBMCP_ENABLED=false
RRHH_AUTO_LIQUIDACIONES_UI_FALLBACK=false

# Google Maps and routing
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_public_google_maps_api_key
GOOGLE_MAPS_API_KEY=your_server_google_maps_api_key
GOOGLE_MAPS_FLEET_ROUTING_API_KEY=your_fleet_routing_api_key
NEXT_PUBLIC_OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key
GRAPHHOPPER_API_KEY=your_graphhopper_api_key

# Google Cloud credentials
GOOGLE_CLOUD_PROJECT_ID=your_google_cloud_project_id
GOOGLE_CLOUD_REGION=southamerica-east1
GOOGLE_CLOUD_SERVICE_ACCOUNT_BASE64=your_base64_encoded_service_account_json
# GOOGLE_CLOUD_SERVICE_ACCOUNT_PATH=./google-cloud-service-account.json
GOOGLE_CLOUD_CREDENTIALS=./google-cloud-service-account.json
GOOGLE_CLOUD_CREDENTIALS_BASE64=your_base64_encoded_google_credentials_json

# Gemini
GOOGLE_GEMINI_API_KEY=your_gemini_api_key
GOOGLE_GEMINI_MODEL=gemini-2.5-flash
GOOGLE_GEMINI_LOCATION=us-central1
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=

# Vertex AI
GOOGLE_VERTEX_AI_ENABLED=true
GOOGLE_VERTEX_AI_LOCATION=us-central1

# Document AI
GOOGLE_DOCUMENT_AI_PROJECT_ID=your_document_ai_project_id
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID_FACTURAS=your_facturas_processor_id
GOOGLE_DOCUMENT_AI_PROCESSOR_ID_REMITOS=your_remitos_processor_id

# Dialogflow
GOOGLE_DIALOGFLOW_PROJECT_ID=your_dialogflow_project_id
GOOGLE_DIALOGFLOW_AGENT_ID=your_dialogflow_agent_id
GOOGLE_DIALOGFLOW_LANGUAGE_CODE=es-AR

# Speech-to-Text
GOOGLE_SPEECH_TO_TEXT_ENABLED=true
GOOGLE_SPEECH_TO_TEXT_LANGUAGE_CODE=es-AR

# AutoML / optimization toggles
GOOGLE_AUTOML_ENABLED=false
GOOGLE_AUTOML_LOCATION=us-central1
GOOGLE_OPTIMIZATION_API_ENABLED=false

# WhatsApp provider
WHATSAPP_PROVIDER=auto
WHATSAPP_ENABLE_BUTTONS=true

# WhatsApp Meta
WHATSAPP_META_ACCESS_TOKEN=your_whatsapp_meta_access_token
WHATSAPP_META_PHONE_NUMBER_ID=your_whatsapp_meta_phone_number_id
WHATSAPP_META_APP_ID=your_whatsapp_meta_app_id
WHATSAPP_META_APP_SECRET=your_whatsapp_meta_app_secret
WHATSAPP_META_VERIFY_TOKEN=change-this-to-a-long-random-verify-token
WHATSAPP_META_WEBHOOK_URL=https://your-domain.com/api/webhooks/whatsapp-meta

# Kapso
KAPSO_API_KEY=your_kapso_api_key
KAPSO_WHATSAPP_PHONE_NUMBER_ID=your_kapso_phone_number_id
KAPSO_WHATSAPP_WEBHOOK_SECRET=your_kapso_webhook_secret
KAPSO_WEBHOOK_SECRET=
KAPSO_WHATSAPP_BASE_URL=https://api.kapso.ai/meta/whatsapp

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=your_twilio_whatsapp_number

# Botpress compatibility
BOTPRESS_WEBHOOK_URL=your_botpress_webhook_url
BOTPRESS_API_KEY=your_botpress_api_key
BOTPRESS_WEBHOOK_TOKEN=your_botpress_webhook_token

# Cron / background jobs
CRON_SECRET=generate-a-long-random-secret

# Hik-Connect (RRHH)
HIK_CONNECT_BASE_URL=https://your-hik-connect-openapi-base-url
HIK_CONNECT_API_KEY=your-hik-connect-api-key
HIK_CONNECT_API_SECRET=your-hik-connect-api-secret
HIK_CONNECT_TOKEN_PATH=/api/hccgw/platform/v1/token/get
HIK_CONNECT_EVENTS_PATH=/api/hccgw/acs/v1/event/certificaterecords/search
HIK_CONNECT_EVENTS_METHOD=POST
HIK_CONNECT_AUTH_MODE=hcc_token
HIK_CONNECT_PERSON_MAP=
HIK_CONNECT_PAGE_SIZE=200
HIK_CONNECT_MAX_PAGES=100
HIK_CONNECT_MAX_PAGES_HISTORICAL=100
HIK_ATTENDANCE_DEBOUNCE_MINUTES=1
HIK_SPLIT_TURNO_HORA=13:30
HORA_LIMITE_ENTRADA=08:15

# Balanza / pesaje
BALANZA_API_KEY=
BALANZA_MODE=
BALANZA_TIPO=
BALANZA_URL=
